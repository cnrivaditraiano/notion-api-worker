{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "compatibility_date": "2025-04-08",
  "name": "romaper2-notion-worker",
  "workers_dev": true,
  "main": "src/index.ts",
  "routes": [
    {
      "pattern": "blog.romaper2.com",
      "zone_name": "romaper2.com",
      "custom_domain": true,
    }
  ],
  "preview_urls": true
  //   "route": " romaper2-notion-worker.dev-1c1.workers.dev/*"
}